# ========================================
# НАСТРОЙКИ TELEGRAM БОТА "ОРЁЛ ИЛИ РЕШКА"
# ========================================

# 🔑 ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ
# ========================================

# Токен вашего Telegram бота (получите у @BotFather)
# Пример: BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=your_bot_token_here

# ========================================
# НАСТРОЙКИ ИГРЫ (ОПЦИОНАЛЬНО)
# ========================================

# Минимальная ставка (по умолчанию: 1)
MIN_BET=1

# Максимальная ставка (по умолчанию: 1000)
MAX_BET=1000

# Время ожидания ответа на дуэль в секундах (по умолчанию: 60)
DUEL_TIMEOUT=60

# Время ожидания выбора в игре в секундах (по умолчанию: 30)
GAME_TIMEOUT=30

# ========================================
# НАСТРОЙКИ ЛОГИРОВАНИЯ (ОПЦИОНАЛЬНО)
# ========================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Файл для записи логов
LOG_FILE=bot.log

# ========================================
# НАСТРОЙКИ БАЗЫ ДАННЫХ (ОПЦИОНАЛЬНО)
# ========================================

# Путь к файлу базы данных
DB_PATH=game_database.db

# ========================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ (ОПЦИОНАЛЬНО)
# ========================================

# Режим отладки (True/False)
DEBUG=False

# Интервал очистки истекших игр в секундах (по умолчанию: 300)
CLEANUP_INTERVAL=300

# ========================================
# ПРИМЕРЫ НАСТРОЕК
# ========================================

# Для разработки:
# DEBUG=True
# LOG_LEVEL=DEBUG

# Для продакшена:
# DEBUG=False
# LOG_LEVEL=WARNING

# Для тестирования:
# MIN_BET=1
# MAX_BET=100
# DUEL_TIMEOUT=30